generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  Active
  Suspended
  Invited
}

enum ChannelType {
  WhatsApp
  Meta
  Web
  Email
  Voice
  Telegram
  SMS
}

enum PropertyStatus {
  Available
  Reserved
  Sold
  Rented
}

enum DocStatus {
  Draft
  PendingApproval
  Approved
  Rejected
  Signed
}

enum TaskPriority {
  Low
  Medium
  High
  Urgent
}

enum FieldType {
  text
  number
  select
  multiselect
  date
  datetime
  boolean
  textarea
  gallery
  location
  repeater
  url
  email
  phone
  currency
  percentage
  json
}

model Workspace {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  domain            String?  @unique
  industry          String   @default("General")
  logo              String?
  subscriptionTier  String   @default("Professional")
  isActive          Boolean  @default(true)
  settings          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  quotas              WorkspaceQuota?
  departments         Department[]
  teams               Team[]
  users               User[]
  roles               Role[]
  permissions         Permission[]
  entityTypes         EntityType[]
  modules             Module[]
  workspaceModules    WorkspaceModule[]
  customFields       CustomField[]
  templates          Template[]
  contacts           Contact[]
  leads              Lead[]
  deals              Deal[]
  propertyTypes      PropertyType[]
  properties         Property[]
  pipelines          Pipeline[]
  pipelineStages    PipelineStage[]
  pipelineTransitions PipelineTransition[]
  flowActions       FlowAction[]
  conversations      Conversation[]
  documents         Document[]
  tasks             Task[]
  activities         Activity[]
  webhooks           Webhook[]
  apiKeys            ApiKey[]
  tickets            Ticket[]
  auditLogs          AuditLog[]
}

model WorkspaceQuota {
  workspaceId      String   @id
  maxUsers       Int      @default(10)
  maxLeads       Int      @default(1000)
  maxDeals       Int      @default(500)
  maxProperties  Int      @default(500)
  maxStorageMb   Int      @default(1000)
  usedStorageMb  Int      @default(0)
  maxApiCallsPerDay Int   @default(10000)
  usedApiCallsToday Int   @default(0)
  apiCallsResetAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_quotas")
}

model Department {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teams     Team[]
  users     User[]

  @@index([workspaceId])
}

model Team {
  id           String   @id @default(uuid())
  workspaceId  String
  departmentId String?
  name         String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  users     User[]

  @@index([workspaceId])
}

model User {
  id               String     @id @default(uuid())
  workspaceId      String
  departmentId    String?
  teamId          String?
  email           String     @unique
  passwordHash    String?
  firstName       String
  lastName        String
  avatar          String?
  status          UserStatus @default(Invited)
  isWorkspaceOwner Boolean  @default(false)
  lastLoginAt     DateTime?
  metadata        Json       @default("{}")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  sessions           Session[]
  accounts           Account[]
  userRoles          UserRole[]
  leadsOwned        Lead[]
  dealsOwned        Deal[]
  contacts          Contact[]
  assignedTasks     Task[]
  activities         Activity[]
  documentsCreated   Document[]
  ticketsOwned       Ticket[]    @relation("TicketOwner")
  ticketsAssigned    Ticket[]    @relation("TicketAssignee")
  ticketMessages    TicketMessage[]
  auditLogs         AuditLog[]

  @@index([workspaceId])
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String   @id @default(uuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  description  String?
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userRoles UserRole[]
  permissions RolePermission[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Permission {
  id          String   @id @default(uuid())
  workspaceId String
  action      String
  entityType  String?
  description String?
  createdAt   DateTime @default(now())

  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([workspaceId, action])
  @@index([workspaceId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model EntityType {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customFields  CustomField[]
  pipelines     Pipeline[]
  flowActions  FlowAction[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model Module {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())

  workspaceModules WorkspaceModule[]
  workspaces       Workspace[]
}

model WorkspaceModule {
  workspaceId String
  moduleId    String
  isEnabled   Boolean @default(true)
  settings    Json    @default("{}")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([workspaceId, moduleId])
}

model CustomField {
  id             String     @id @default(uuid())
  workspaceId    String
  entityTypeId   String
  name           String
  slug           String
  fieldType      FieldType
  description    String?
  placeholder    String?
  defaultValue   Json?
  options        Json?
  repeaterFields Json?
  isRequired     Boolean    @default(false)
  minValue       Decimal?
  maxValue       Decimal?
  minLength      Int?
  maxLength      Int?
  pattern        String?
  displayOrder   Int        @default(0)
  visibleOnTable Boolean    @default(true)
  visibleOnForm  Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  values    CustomFieldValue[]

  @@unique([workspaceId, entityTypeId, slug])
}

model CustomFieldValue {
  id        String    @id @default(uuid())
  fieldId   String
  entityId String
  value     Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  field CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([entityId])
}

model Template {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String   @unique
  industry    String?
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Contact {
  id            String       @id @default(uuid())
  workspaceId   String
  ownerId       String?
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  companyName   String?
  sourceChannel ChannelType?
  metadata      Json         @default("{}")
  tags          Json         @default("[]")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  conversations Conversation[]

  @@index([workspaceId])
}

model Lead {
  id                String       @id @default(uuid())
  workspaceId       String
  ownerId           String?
  sourceChannel     ChannelType?
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  country           String?
  companyName       String?
  notes             String?
  metadata          Json         @default("{}")
  tags              Json         @default("[]")
  convertedToDealId String?
  convertedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  deals         Deal[]
  conversations Conversation[]
  tasks        Task[]

  @@index([workspaceId])
}

model Deal {
  id                String    @id @default(uuid())
  workspaceId       String
  leadId           String?
  ownerId          String?
  title            String
  value            Decimal   @default(0)
  currency         String    @default("USD")
  probability      Int       @default(50)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  notes            String?
  metadata         Json      @default("{}")
  tags             Json      @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  owner     User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  documents     Document[]
  dealProperties DealProperty[]
  tasks        Task[]

  @@index([workspaceId])
}

model DealProperty {
  dealId     String
  propertyId String
  isPrimary  Boolean @default(false)

  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([dealId, propertyId])
}

model PropertyType {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String?
  icon        String?
  description String?
  createdAt   DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  properties Property[]

  @@unique([workspaceId, slug])
}

model Property {
  id               String         @id @default(uuid())
  workspaceId      String
  propertyTypeId   String?
  title            String
  description      String?
  price            Decimal?
  currency         String         @default("USD")
  status           PropertyStatus @default(Available)
  location         Json?
  bedrooms         Int?
  bathrooms        Int?
  areaSqft         Int?
  yearBuilt        Int?
  images           Json           @default("[]")
  virtualTourUrl   String?
  pfReference      String?
  bayutReference   String?
  metadata         Json           @default("{}")
  tags             Json           @default("[]")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  propertyType PropertyType?  @relation(fields: [propertyTypeId], references: [id], onDelete: SetNull)

  dealProperties DealProperty[]

  @@index([workspaceId])
}

model Pipeline {
  id           String   @id @default(uuid())
  workspaceId  String
  entityTypeId String
  name         String
  description  String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  stages     PipelineStage[]
  transitions PipelineTransition[]

  @@index([workspaceId])
}

model PipelineStage {
  id             String   @id @default(uuid())
  pipelineId     String
  workspaceId    String
  name           String
  description    String?
  colorCode      String   @default("#000000")
  stageOrder     Int
  isStart        Boolean  @default(false)
  isEnd          Boolean  @default(false)
  isWon          Boolean  @default(false)
  isLost         Boolean  @default(false)
  allowedActions Json     @default("[]")
  createdAt      DateTime @default(now())

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transitionsFrom PipelineTransition[] @relation("TransitionFromStage")
  transitionsTo   PipelineTransition[] @relation("TransitionToStage")

  @@index([pipelineId])
  @@index([workspaceId])
}

model PipelineTransition {
  id          String   @id @default(uuid())
  workspaceId String
  pipelineId  String
  fromStageId String
  toStageId   String
  action      String?
  conditions  Json?
  createdAt   DateTime @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  fromStage PipelineStage @relation("TransitionFromStage", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStage   PipelineStage @relation("TransitionToStage", fields: [toStageId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FlowAction {
  id            String   @id @default(uuid())
  workspaceId   String
  entityTypeId  String
  name          String
  slug          String
  description   String?
  icon          String?
  requiresInput Boolean  @default(false)
  inputFields   Json?
  webhookUrl    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Conversation {
  id               String       @id @default(uuid())
  workspaceId      String
  leadId           String?
  contactId        String?
  channel          ChannelType
  externalThreadId String?
  status           String       @default("active")
  createdAt        DateTime     @default(now())
  lastMessageAt    DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  messages Message[]

  @@index([workspaceId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderType     String
  senderId       String?
  content        String?
  mediaUrl        String?
  metadata       Json     @default("{}")
  sentAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Document {
  id          String    @id @default(uuid())
  workspaceId String
  dealId      String?
  makerId     String?
  title       String
  docType     String?
  fileUrl     String?
  status      DocStatus @default(Draft)
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  maker     User?     @relation(fields: [makerId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Task {
  id          String      @id @default(uuid())
  workspaceId String
  assignedToId String?
  leadId      String?
  dealId      String?
  title       String
  description String?
  dueDate     DateTime
  priority    TaskPriority @default(Medium)
  isCompleted Boolean    @default(false)
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Activity {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String?
  entityType  String
  entityId    String
  action      String
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}

model Webhook {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  url         String
  events      Json
  secret      String?
  isActive    Boolean  @default(true)
  headers     Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  prefix      String
  permissions Json      @default("[]")
  rateLimit   Int       @default(1000)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AuditLog {
  id            String     @id @default(uuid())
  workspaceId   String
  userId        String?
  action        String
  entityType    String
  entityId      String?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  location      Json?
  metadata      Json       @default("{}")
  createdAt     DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([entityType, entityId])
  @@index([userId])
}

model Ticket {
  id          String      @id @default(uuid())
  workspaceId String
  userId      String?
  assigneeId  String?
  subject     String
  description String?
  status      String      @default("open")
  priority    TaskPriority @default(Medium)
  category    String?
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation("TicketOwner", fields: [userId], references: [id], onDelete: SetNull)
  assignee  User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  messages TicketMessage[]

  @@index([workspaceId])
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String?
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}
